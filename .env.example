# Google OAuth (for admin sign-in)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: restrict to Google Workspace domain
GOOGLE_WORKSPACE_DOMAIN=yourdomain.com

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret

# For static export (GitHub Pages)
NEXT_PUBLIC_STATIC_EXPORT=false
NEXT_PUBLIC_BASE_PATH=https://daisyxlee.github.io/d201tm/

NEXT_PUBLIC_GITHUB_USERNAME=daisyxlee
NEXT_PUBLIC_GITHUB_REPO=d201tm